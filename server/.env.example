# ============================================================
# WOOL MONITORING ENTERPRISE v2 - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# SERVER
NODE_ENV=production
PORT=5000

# ============================================================
# MONGODB ATLAS (CLOUD DATABASE)
# ============================================================
# Steps to get connection string:
# 1. Go to https://cloud.mongodb.com
# 2. Create cluster → Connect → Drivers → Node.js
# 3. Copy the connection string below, replace placeholders
MONGO_URI=mongodb+srv://bhadoriaanil98_db_user:<db_password>@cluster0.g9ons3z.mongodb.net/?appName=Cluster0

# ============================================================
# JWT SECURITY
# ============================================================
# Generate strong secrets:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=e6cc4d852a0d82414d7a6c6fbc3a47c108d5f145cb51fa0dc2321a81b42e1d2362e109299a36da8c1ecd59fb8cc7d4b96b5de11db1f9c982e431bd9c962ef3bb
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=c930b1b90aa8835113027460770ce2ef96e5457324b26e8551fcbbaebb0c6c3cea615503d6b4b8916ee4658897dfb4da2380e092f49f16c1e99d4c3b33b03037
JWT_REFRESH_EXPIRE=7d

# ============================================================
# REDIS (CACHING + RATE LIMITING)
# ============================================================
